# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOW_ALL=1
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Firebase Admin credentials
# Option 1: path to downloaded service account JSON
FIREBASE_CREDENTIALS_FILE=/absolute/path/to/service-account.json
# Option 2: inline JSON string (use one of the two options)
# FIREBASE_CREDENTIALS_JSON={"type":"service_account", ...}

# Frontend origin (set CORS_ALLOWED_ORIGINS if you disable CORS_ALLOW_ALL)
# CORS_ALLOWED_ORIGINS=http://localhost:5173
